# General
COMOGASTOAPP_ENV=dev
COMOGASTOAPP_PLATFORM_NAME=comogastoapp-platform

# PostgreSQL
POSTGRES_USER=comogastoapp
POSTGRES_PASSWORD=comogastoapp_password
POSTGRES_DB=comogastoapp_platform
POSTGRES_PRIMARY_PORT=5432
POSTGRES_REPLICA_PORT=5433
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=replicator_password

# Kafka KRaft
KAFKA_CLUSTER_ID=COMOGASTOAPP-platform-cluster
KAFKA_BROKER_PORT=9092
KAFKA_UI_PORT=8085

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# Spring
SPRING_PROFILES_ACTIVE=dev

# JWT
JWT_ISSUER=COMOGASTOAPP-platform
JWT_SECRET=change_this_secret_with_minimum_256_bits
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_PORT=16686
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
PMM_SERVER_PORT=8443
PMM_ADMIN_USER=usuario_admin
PMM_ADMIN_PASSWORD=password_admin

# Frontend
PLATFORM_ADMIN_WEB_PORT=4200